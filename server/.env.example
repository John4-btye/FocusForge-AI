# Local development examples
FLASK_ENV=development
DATABASE_URL=postgresql://localhost/focusforge_ai
JWT_SECRET_KEY=replace-this-with-a-secret-key
GROQ_API_KEY=replace-this-with-your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b

# Render production notes:
# Set these values in the Render service Environment tab, not in source code.
# DATABASE_URL should come from the Render Postgres service: focusforge-ai-db
# FLASK_ENV should be production
# JWT_SECRET_KEY should be a long unique secret
# GROQ_API_KEY should be your private Groq API key
# GROQ_MODEL can stay openai/gpt-oss-120b or another supported Groq model
